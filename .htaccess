# Apache configuration for PWA

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Serve HTML files as UTF-8
    AddDefaultCharset UTF-8

    # Cache static assets
    <IfModule mod_expires.c>
        ExpiresActive On
        ExpiresByType image/png "access plus 1 year"
        ExpiresByType image/svg+xml "access plus 1 year"
        ExpiresByType image/jpg "access plus 1 year"
        ExpiresByType image/jpeg "access plus 1 year"
        ExpiresByType image/gif "access plus 1 year"
        ExpiresByType image/webp "access plus 1 year"
        ExpiresByType text/css "access plus 1 month"
        ExpiresByType application/javascript "access plus 1 month"
        ExpiresByType application/json "access plus 1 month"
    </IfModule>

    # Security headers
    <IfModule mod_headers.c>
        # Service Worker
        Header set Service-Worker-Allowed "/"

        # MIME types
        Header set Content-Type "application/manifest+json" env=manifest
        Header set Content-Type "application/javascript" "environment=js"

        # Cache-Control for Service Worker
        <FilesMatch "\.(js|json)$">
            Header set Cache-Control "public, max-age=604800, immutable"
        </FilesMatch>
    </IfModule>

    # MIME types
    AddType application/manifest+json .json
    AddType application/worker .js
    AddType image/svg+xml .svg

    # Gzip compression
    <IfModule mod_deflate.c>
        AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json
    </IfModule>

    # Brotli compression (if available)
    <IfModule mod_brotli.c>
        AddOutputFilterByType BROTLI text/html text/css application/javascript application/json
    </IfModule>
</IfModule>
